filters:
  or:
    - 'domain == "B-安全与信任"'
    - 'domain.contains("B-安全与信任")'

properties:
  description:
    displayName: "核心问题"
  parent:
    displayName: "父笔记"

views:
  - type: table
    name: "域内笔记"
    order:
      - file.name
      - description
      - parent
    groupBy:
      property: parent
      direction: ASC
