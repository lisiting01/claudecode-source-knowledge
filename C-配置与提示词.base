filters:
  or:
    - 'domain == "C-配置与提示词"'
    - 'domain.contains("C-配置与提示词")'

properties:
  description:
    displayName: "核心问题"
  parent:
    displayName: "父笔记"

views:
  - type: table
    name: "域内笔记"
    order:
      - file.name
      - description
      - parent
    groupBy:
      property: parent
      direction: ASC
